<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }} · {{ site.name }}</title>
    <meta name="description" content="{{ site.description }}" />
    <link rel="icon" href="/img/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="min-h-screen flex flex-col text-gray-800 bg-white">
    <header class="border-b border-gray-200">
      <nav class="max-w-2xl mx-auto px-4 py-4 flex gap-6">
        <a href="/" class="font-semibold">{{ site.name }}</a>
        <a href="/blog/" class="text-gray-600 hover:text-gray-900">Blog</a>
        <a href="/demos/" class="text-gray-600 hover:text-gray-900">Demos</a>
      </nav>
    </header>

    <main class="flex-1 max-w-2xl mx-auto px-4 py-10 w-full">
      {{ content | safe }}
    </main>

    <footer class="border-t border-gray-200">
      <div class="max-w-2xl mx-auto px-4 py-6 text-sm text-gray-500">
        © {{ site.author }}
      </div>
    </footer>
  </body>
</html>
