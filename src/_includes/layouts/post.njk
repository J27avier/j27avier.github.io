---
layout: layouts/base.njk
---
<article class="leading-relaxed [&_p]:mt-4 [&_h2]:mt-8 [&_h2]:text-xl [&_h2]:font-bold [&_a]:text-accent [&_a]:underline [&_a]:decoration-accent/50 [&_a]:underline-offset-2 [&_code]:font-mono [&_code]:text-sm [&_code]:text-teal">
  <p class="font-mono text-xs uppercase tracking-wider text-muted">{{ page.date | readableDate }}</p>
  <h1 class="text-3xl font-bold mt-1 mb-2">{{ title }}</h1>
  {{ content | safe }}
</article>

<p class="mt-12 font-mono text-xs">
  <a href="/blog/" class="text-muted hover:text-accent">← back to blog</a>
</p>
