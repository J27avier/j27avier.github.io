---
layout: layouts/base.njk
title: Blog
---
<h1 class="text-2xl font-bold mb-6">Blog</h1>

<ul class="space-y-3">
  {% for post in collections.post | reverse %}
    <li class="flex gap-3">
      <span class="text-sm text-gray-400 shrink-0">{{ post.date | readableDate }}</span>
      <a href="{{ post.url }}" class="text-blue-600 hover:underline">{{ post.data.title }}</a>
    </li>
  {% else %}
    <li class="text-gray-500">No posts yet.</li>
  {% endfor %}
</ul>
