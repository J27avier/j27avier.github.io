---
layout: layouts/base.njk
title: Home
---
<section class="mb-12 flex flex-col sm:flex-row items-center gap-6">
  <img
    src="/img/profile.png"
    alt="{{ site.name }}"
    class="w-32 h-32 rounded-full ring-1 ring-gray-200 shrink-0"
  />
  <div class="text-center sm:text-left">
    <h1 class="text-3xl font-bold mb-2">Javier Sales-Ortiz</h1>
    <p class="text-gray-600">
      Software Engineer at
      <a href="https://rlcore.ai" class="text-blue-600 hover:underline">RL Core</a>.
    </p>
    <p class="text-gray-600 mt-2">
      I care about software architecture and making software talk to hardware.
      Away from the keyboard, I'm at another one... the piano.
    </p>
  </div>
</section>

<nav class="mb-12 flex justify-center gap-6 text-gray-500">
  <a
    href="https://www.linkedin.com/in/javier-sales-ortiz/"
    target="_blank" rel="noopener"
    class="flex items-center gap-1.5 hover:text-gray-900"
    aria-label="LinkedIn"
  >
    {% include "icons/linkedin.svg" %}
    <span class="text-sm">LinkedIn</span>
  </a>
  <a
    href="https://github.com/J27avier"
    target="_blank" rel="noopener"
    class="flex items-center gap-1.5 hover:text-gray-900"
    aria-label="GitHub"
  >
    {% include "icons/github.svg" %}
    <span class="text-sm">GitHub</span>
  </a>
  <a
    href="https://scholar.google.com/citations?user=GOrXQLcAAAAJ"
    target="_blank" rel="noopener"
    class="flex items-center gap-1.5 hover:text-gray-900"
    aria-label="Google Scholar"
  >
    {% include "icons/scholar.svg" %}
    <span class="text-sm">Scholar</span>
  </a>
</nav>

<section>
  <h2 class="text-xl font-semibold mb-6">Past Projects</h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
    {% for project in projects %}
      <button
        type="button"
        class="group text-center cursor-pointer focus:outline-none"
        onclick="document.getElementById('project-{{ loop.index }}').showModal()"
      >
        <div class="aspect-square overflow-hidden rounded-2xl ring-1 ring-gray-200 transition group-hover:ring-blue-400 group-focus-visible:ring-2 group-focus-visible:ring-blue-400">
          <img
            src="/img/portfolio/{{ project.img }}"
            alt="{{ project.title }}"
            class="w-full h-full object-cover scale-[1.12] transition group-hover:opacity-90"
          />
        </div>
        <h3 class="mt-3 text-sm font-medium text-gray-800">{{ project.title }}</h3>
        <p class="text-xs text-gray-400">{{ project.date }}</p>
      </button>
    {% endfor %}
  </div>

  {# Expanding detail modals — one native <dialog> per project. #}
  {% for project in projects %}
    <dialog
      id="project-{{ loop.index }}"
      class="m-auto w-[min(90vw,42rem)] rounded-lg p-0 backdrop:bg-black/50"
    >
      <form method="dialog" class="flex justify-end p-2">
        <button class="text-gray-400 hover:text-gray-700 text-2xl leading-none px-2" aria-label="Close">&times;</button>
      </form>
      <div class="px-6 pb-8 text-center">
        <img
          src="/img/portfolio/{{ project.img }}"
          alt="{{ project.title }}"
          class="w-full max-w-md mx-auto object-contain"
        />
        <h3 class="mt-4 text-2xl font-bold">{{ project.title }}</h3>
        <p class="text-sm text-gray-500">{{ project.category }} · {{ project.date }}</p>
        <p class="mt-2 text-xs uppercase tracking-wide text-gray-400">{{ project.tech }}</p>
        <div class="mt-4 text-left text-gray-600 leading-relaxed [&_a]:text-blue-600 [&_a]:underline">
          {{ project.description | safe }}
        </div>
      </div>
    </dialog>
  {% endfor %}
</section>
